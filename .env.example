# ONE configuration file for local Vite, VPS Docker and Supabase Edge Functions.
# Copy this file to .env and never commit the real .env.

# Frontend public values: Supabase Dashboard -> Project Settings -> API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# VPS only: choose an unused local port for the Docker frontend container.
STREET_FAMILY_PORT=18087

# Telegram bot: obtain token and username from @BotFather.
TELEGRAM_BOT_TOKEN=123456:replace_with_bot_token
TELEGRAM_BOT_USERNAME=replace_with_bot_username_without_at

# Generate long random values. These remain server-side in Supabase Functions.
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_secret
KYC_PURGE_SECRET=replace_with_long_random_secret

# Numeric Telegram user IDs separated by commas. These users become admins.
TELEGRAM_ADMIN_IDS=123456789,987654321

# Public HTTPS frontend URL after Nginx/Certbot setup.
TELEGRAM_MINI_APP_URL=https://street.example.com
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=600
