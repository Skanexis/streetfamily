# Public frontend build settings. The publishable Supabase key is expected in browser code.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Pick a free loopback port on the VPS. Nginx will proxy the domain to this port.
STREET_FAMILY_PORT=18087
